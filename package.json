{
  "name": "test-task-cir",
  "version": "0.0.1",
  "description": "Test task Program Capacity and Invoice Reservation",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "start:dev": "nodemon app/index.js",
    "db:create": "env-cmd -f ./.env.local node ./tools/create-db.js",
    "db:migrate": "env-cmd -f ./.env.local knex migrate:up",
    "db:migrate:down": "env-cmd -f ./.env.local knex migrate:down",
    "db:migrate:all": "env-cmd -f ./.env.local knex migrate:latest",
    "test:unit": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --testPathIgnorePatterns=integration\\.test\\.js$",
    "test:integration": "node -e \"const fs=require('node:fs'); if (!fs.existsSync('.env.test')) { console.error('Missing .env.test.'); process.exit(1); }\" && env-cmd -f ./.env.test node --experimental-vm-modules ./node_modules/jest/bin/jest.js --testRegex=integration\\.test\\.js$"
  },
  "dependencies": {
    "@hapi/boom": "^10.0.1",
    "@hapi/hapi": "^21.3.9",
    "@hapi/inert": "^7.1.0",
    "hapi-pino": "^12.1.0",
    "joi": "^17.13.1",
    "knex": "^3.1.0",
    "lodash": "^4.18.1",
    "objection": "^3.1.5",
    "pg": "^8.12.0",
    "pino": "^9.2.0",
    "pino-pretty": "^11.2.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@stylistic/eslint-plugin": "^4.0.1",
    "env-cmd": "^10.1.0",
    "eslint": "^9.21.0",
    "eslint-plugin-import": "^2.31.0",
    "globals": "^15.4.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sergiy-mykhailov/test-task-cir.git"
  },
  "author": "Serhii Mykhailov",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/sergiy-mykhailov/test-task-cir/issues"
  },
  "homepage": "https://github.com/sergiy-mykhailov/test-task-cir#readme"
}
