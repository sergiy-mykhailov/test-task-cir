NODE_ENV=development

SERVICE_PORT=9000
SERVICE_HOST=0.0.0.0
API_TOKEN=local-dev-token

# database
DATABASE_HOST=cir.database
DATABASE_PORT=5432
DATABASE_NAME=cir_db
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres

# postgres envs
POSTGRES_HOST=cir.database
POSTGRES_PORT=5432
POSTGRES_NAME=cir_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# kafka
KAFKA_ENABLED=true
KAFKA_BROKERS=cir-kafka:19092
KAFKA_CLIENT_ID=cir-service
KAFKA_CONSUMER_GROUP_ID=cir-service-treasury
KAFKA_TREASURY_EVENTS_TOPIC=treasury.capacity.events
KAFKA_FROM_BEGINNING=false
